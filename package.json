{
  "name": "devcore-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/home",
    "apps/home-legacy",
    "apps/editor",
    "apps/packager",
    "apps/extensions-gallery",
    "apps/docs",
    "apps/holdover",
    "apps/library-concile",
    "apps/desktop-old-cat-version",
    "packages/api-module",
    "packages/audio",
    "packages/bfunemoji",
    "packages/blocks",
    "packages/devcore-theme",
    "packages/markdown",
    "packages/markdown-new",
    "packages/object-libraries",
    "packages/paint",
    "packages/paper",
    "packages/parser",
    "packages/pmp-protobuf",
    "packages/render",
    "packages/render-fonts",
    "packages/storage",
    "packages/svelte-ui",
    "packages/svg-renderer",
    "packages/vm",
    "services/backend-api",
    "tools/penguinbot-public",
    "tools/scripts"
  ],
  "scripts": {
    "install:home": "npm install --prefix apps/home --workspaces=false --legacy-peer-deps",
    "install:editor": "npm install --prefix apps/editor --workspaces=false --legacy-peer-deps",
    "build:home": "npm run build --prefix apps/home",
    "build:vercel": "node scripts/build-vercel-output.mjs",
    "build:editor": "npm run build --prefix apps/editor",
    "build:packager": "npm run build --prefix apps/packager",
    "dev:home": "npm run dev --prefix apps/home",
    "dev:editor": "npm run start --prefix apps/editor",
    "dev:packager": "npm run start --prefix apps/packager"
  }
}
